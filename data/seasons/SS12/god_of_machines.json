  "glossary": {
    "720": {
      "name": "Barrier",
      "description": "Gains a Shield equal to 20% of the sum of Max Life and Max Energy Shield, absorbing 50% of the Hit Damage taken. Cannot gain another Barrier when a Barrier is present."
    },
    "750": {
      "name": "Command",
      "description": "Every point of Command will grant Synthetic Troop Minions +3% additional damage, +-2% additional damage taken, ++2% Movement Speed, and a bigger Tracking Area.The lowest Command is -100 while the highest is 100. When Command is not 0, 13 point(s) will be returned (reduced/granted) every second until it becomes 0. For every 10 Command increased, +7 additional points will be returned.Synthetic Troop Minions' Duration will not reduce when Command is a positive value."
    },
    "759": {
      "name": "Growth",
      "description": "Spirit Magi grow into the next Stage for every 100 Growth. They start at Stage 1 and can grow until they reach Stage 5. For every 8 Growth they have, Spirit Magi gain +1% Physique, +10% additional Skill Area, and a bonus every stage:At Stage 2, +30% chance for them to use Enhanced Skill chance.At Stage 3, their Enhanced Skills become stronger.At Stage 4, their Empower Skills become stronger.At Stage 5, they +50% additional damage, +10% additional Skill Area, and gain increased Movement Speed and Tracking Area.The max Growth is 1000."
    },
    "173": {
      "name": "Applied Weapon Bonuses",
      "description": "Includes a weapon's Base Damage and affixes, but does not affect Minions' Base Attack Speed and Base Critical Strike Rating."
    },
    "157": {
      "name": "Enhanced Skill",
      "description": "Chance to change the skill into a stronger Enhanced Skill when Spirit Magus uses a Base Skill. The chance can be increased, and at 100%, Spirit Magi will no longer use Base Skills and always use Enhanced Skills"
    },
    "158": {
      "name": "Ultimate",
      "description": "When in a certain state, Spirit Magi use their Ultimate with extremely high strength"
    },
    "504": {
      "name": "Ailment Damage",
      "description": "Trauma, Ignite, and Wilt"
    },
    "10000106": {
      "name": "Quickness",
      "description": "Additionally increases Attack Speed, Cast Speed, Movement Speed, and Mobility Skill Cooldown Recovery Time by 8%"
    },
    "10000100": {
      "name": "Attack Aggression",
      "description": "Additionally increases Attack Speed and Attack Damage by 5%. Increases Movement Speed by 10%"
    },
    "10000101": {
      "name": "Spell Aggression",
      "description": "Additionally increases Cast Speed and Spell Damage by 7%. Increases Mobility Skill Cooldown Recovery Speed by 7%"
    }
  },
