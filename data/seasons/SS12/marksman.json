    },
    "107": {
      "name": "Jump",
      "description": "Upon hitting a target, a horizontal Projectile or Chain Skill jumps to another target nearby"
    },
    "109": {
      "name": "Penetrate",
      "description": "Horizontal Projectiles pass through the targets they hit, continuing along their original trajectory until reaching the Penetration limit."
    }
