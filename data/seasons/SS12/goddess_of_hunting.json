  "glossary": {
    "716": {
      "name": "Agility Blessing",
      "description": "Every stack of Agility Blessing grants +4% Attack and Cast Speed and +2% additional damage. Initial max stacks: 4"
    },
    "10000106": {
      "name": "Quickness",
      "description": "Additionally increases Attack Speed, Cast Speed, Movement Speed, and Mobility Skill Cooldown Recovery Time by 8%"
    },
    "106": {
      "name": "Split",
      "description": "Upon hitting a target, a Parabolic Projectile Splits into multiple secondary Projectiles"
    },
    "733": {
      "name": "Life Regain",
      "description": "Based on the Missing Life (including Sealed Life), restores a portion of Life on hit. This effect has a 0.5s interval."
    },
    "734": {
      "name": "Shield regain",
      "description": "Based on the Missing Energy Shield, restores a portion of Energy Shield on hit. This effect may only appear once every 0.5s."
    }
  },
