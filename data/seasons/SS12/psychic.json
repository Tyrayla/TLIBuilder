  "glossary": {
    "180": {
      "name": "Ill Omen",
      "description": "Inflicts enemies affected by Ominous Curse with 1 stack of Ill Omen whenever their Damage Over Time, Reaping Damage, Spacetime Turbulence Damage, and additional damage taken reaches a certain percentage of their Max Life (8% for non-Elite enemies and 5% for Elite enemies)Maximum stacks of Ill Omen: 10Upon reaching max stacks, eliminates non-Elite enemies and deals True Damage equal to 20% of Max Life to Elite enemies"
    },
    "102": {
      "name": "Nearby",
      "description": "Within 6m"
    },
    "124": {
      "name": "Elite",
      "description": "Elite monsters include rare monsters and bosses"
    },
    "500": {
      "name": "Defense",
      "description": "The sum of Armor, Evasion, and Energy Shield"
    },
    "139": {
      "name": "Injury Buffer",
      "description": "Delays a portion of Hit Damage taken in the next 4s."
    },
    "137": {
      "name": "Affliction",
      "description": "When the Affliction inflicted per second is not 0, the Damage Over Time dealt will continuously inflicts Affliction on the targetThe target takes 1% additional Damage Over Time for every Affliction pointThe max Affliction is 100"
    },
    "10000108": {
      "name": "Torment",
      "description": "Each stack of Torment additionally increases Damage Over Time dealt by 5% for 4s. Stacks up to 3 times"
    },
    "138": {
      "name": "Reaping",
      "description": "Deals a certain amount of True Damage to the target, equivalent to the damage from all DoT effects over a certain period of time"
    },
    "721": {
      "name": "Blur",
      "description": "Gains 100 points of Blur Rating10 Blur Rating is lost per second. Blur is lost once Blur Rating drops to 0+0.25% Chance to Avoid Damage for every point of Blur Rating you haveMax Blur Rating is 100"
    },
    "129": {
      "name": "Charge",
      "description": "Energy Shield starts to charge after the character hasn't taken any damage for 2s at the rate of 20% of Max Energy Shield per second and stops charging if the character takes damage"
    }
  },
