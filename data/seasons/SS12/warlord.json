  "glossary": {
    "710": {
      "name": "Ignite",
      "description": "An Ailment that may be triggered on hit, dealing Fire Damage per second for 4s based on Base Ignite Damage. Unable to stackIgnite cannot be inflicted when Base Ignite Damage is 0"
    },
    "719": {
      "name": "Tenacity Blessing",
      "description": "Every stack of Tenacity Blessing grants an additional 4% damage reduction (multiplies). Initial max stacks: 4."
    },
    "137": {
      "name": "Affliction",
      "description": "When the Affliction inflicted per second is not 0, the Damage Over Time dealt will continuously inflicts Affliction on the targetThe target takes 1% additional Damage Over Time for every Affliction pointThe max Affliction is 100"
    },
    "733": {
      "name": "Life Regain",
      "description": "Based on the Missing Life (including Sealed Life), restores a portion of Life on hit. This effect has a 0.5s interval."
    },
    "734": {
      "name": "Shield regain",
      "description": "Based on the Missing Energy Shield, restores a portion of Energy Shield on hit. This effect may only appear once every 0.5s."
    },
    "502": {
      "name": "Max Resistance",
      "description": "By default, the Max Resistance is 60%. This limit can be increased."
    },
    "10000103": {
      "name": "Fire Infiltration",
      "description": "Additionally increases Fire Damage taken by 13%. Reduces Skill Area by 8%"
    }
  },
