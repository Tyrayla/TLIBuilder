  "glossary": {
    "139": {
      "name": "Injury Buffer",
      "description": "Delays a portion of Hit Damage taken in the next 4s."
    },
    "105": {
      "name": "Fatal Damage",
      "description": "The instance of damage that defeats the target"
    },
    "740": {
      "name": "Fervor rating",
      "description": "+2% Critical Strike Rating for every point of Fervor Rating you have. The Max Fervor Rating is 100."
    },
    "739": {
      "name": "Fighting Will",
      "description": "Accumulates Fervor Rating when you defeat enemies or hit Elite enemies while having Fervor. +2% Critical Strike Rating for every point of Fervor Rating. The Max Fervor Rating is 100 points."
    },
    "102": {
      "name": "Nearby",
      "description": "Within 6m"
    },
    "738": {
      "name": "Knockback direction is reversed",
      "description": "Inverts the Knockback direction"
    },
    "703": {
      "name": "Knockback",
      "description": "Forced to move back by a short distance"
    },
    "711": {
      "name": "Trauma",
      "description": "An Ailment that may be triggered on hit, dealing Physical Damage per second for 4s based on Base Trauma Damage. Unable to stackTrauma cannot be inflicted when Base Trauma Damage is 0"
    },
    "138": {
      "name": "Reaping",
      "description": "Deals a certain amount of True Damage to the target, equivalent to the damage from all DoT effects over a certain period of time"
    },
    "733": {
      "name": "Life Regain",
      "description": "Based on the Missing Life (including Sealed Life), restores a portion of Life on hit. This effect has a 0.5s interval."
    },
    "734": {
      "name": "Shield regain",
      "description": "Based on the Missing Energy Shield, restores a portion of Energy Shield on hit. This effect may only appear once every 0.5s."
    }
  },
