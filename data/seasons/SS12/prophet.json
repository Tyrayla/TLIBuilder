  "glossary": {
    "735": {
      "name": "Frostbite",
      "description": "Frostbite is an Ailment that may be triggered on Cold Damage hits. Frostbitten enemies -10% Attack, Cast, and Movement Speed. Base Frostbite Rating: 10. For every 1 Frostbite Rating, +1% additional Cold Damage taken. The enemy will be Frozen once they have more than 100 Frostbite Rating."
    },
    "736": {
      "name": "Frostbite",
      "description": "Enemies are inflicted with a fixed amount of Frostbite Rating when they are Frostbitten. This can be increased by raising Max Frostbite Rating. The Max Frostbite Rating is 120."
    },
    "707": {
      "name": "Freeze",
      "description": "When a unit's Frostbite Rating exceeds 100, it becomes FrozenFrozen non-Legendary bosses will be Frost-Sealed periodically and cannot act. The Frost-Seal duration is 2s, and the Frost-Seal Interval is 3 for the same unitFrost-Seal ends when Frostbite ends"
    },
    "733": {
      "name": "Life Regain",
      "description": "Based on the Missing Life (including Sealed Life), restores a portion of Life on hit. This effect has a 0.5s interval."
    },
    "734": {
      "name": "Shield regain",
      "description": "Based on the Missing Energy Shield, restores a portion of Energy Shield on hit. This effect may only appear once every 0.5s."
    },
    "10000104": {
      "name": "Cold Infiltration",
      "description": "Additionally increases Cold Damage taken by 13%. Reduces Movement Speed by 5%"
    },
    "737": {
      "name": "Focus Blessing",
      "description": "Every stack of Focus Blessing grants +5% additional damage. Initial max stacks: 4"
    }
  },
