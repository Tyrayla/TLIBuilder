  "glossary": {
    "10000107": {
      "name": "Fortitude",
      "description": "Each stack of Fortitude additionally reduces Hit Damage taken by 5% for 10s.Base Max Fortitude Stacks: 3."
    },
    "501": {
      "name": "Block Ratio",
      "description": "By default, Blocking absorbs 30% damage. Increase Block Ratio to increase the damage absorption ratio."
    },
    "174": {
      "name": "Damage Taken Reduction",
      "description": "Damage mitigation from each independent source can at most reduce the damage taken by 90%."
    },
    "733": {
      "name": "Life Regain",
      "description": "Based on the Missing Life (including Sealed Life), restores a portion of Life on hit. This effect has a 0.5s interval."
    },
    "734": {
      "name": "Shield regain",
      "description": "Based on the Missing Energy Shield, restores a portion of Energy Shield on hit. This effect may only appear once every 0.5s."
    },
    "500": {
      "name": "Defense",
      "description": "The sum of Armor, Evasion, and Energy Shield"
    },
    "126": {
      "name": "Severe Injury",
      "description": "Takes damage that exceeds 50% of the sum of Max Life and Max Energy Shield within 0.5s"
    },
    "719": {
      "name": "Tenacity Blessing",
      "description": "Every stack of Tenacity Blessing grants an additional 4% damage reduction (multiplies). Initial max stacks: 4."
    }
  },
