  "glossary": {
    "756": {
      "name": "Spell Burst",
      "description": "Automatically uses a Spell Skill a certain number of times.When Spell Burst is fully charged, the next Spell Skill used will activate Spell Burst, which will consume all stacks charged and automatically use the Spell Skill the same number of times.Skills that have a cooldown, Triggered Skills, Sentry Skills, Channeled Skills, and Combo Skills cannot activate Spell Burst."
    },
    "767": {
      "name": "Tangle",
      "description": "Generated by the player, it can attach to an enemy and periodically trigger a specified Spell Skill"
    },
    "737": {
      "name": "Focus Blessing",
      "description": "Every stack of Focus Blessing grants +5% additional damage. Initial max stacks: 4"
    },
    "10000101": {
      "name": "Spell Aggression",
      "description": "Additionally increases Cast Speed and Spell Damage by 7%. Increases Mobility Skill Cooldown Recovery Speed by 7%"
    },
    "766": {
      "name": "Dormant Entanglement",
      "description": "When having Dormant Entanglement, +40% additional Tangle Damage for each inactivated Tangle"
    },
    "733": {
      "name": "Life Regain",
      "description": "Based on the Missing Life (including Sealed Life), restores a portion of Life on hit. This effect has a 0.5s interval."
    },
    "734": {
      "name": "Shield regain",
      "description": "Based on the Missing Energy Shield, restores a portion of Energy Shield on hit. This effect may only appear once every 0.5s."
    },
    "129": {
      "name": "Charge",
      "description": "Energy Shield starts to charge after the character hasn't taken any damage for 2s at the rate of 20% of Max Energy Shield per second and stops charging if the character takes damage"
    }
  },
